# =========================
# IMPORTS
# =========================
from scapy.all import sniff
from scapy.layers.inet import TCP, UDP, IP
import pandas as pd
import time
from collections import defaultdict
import matplotlib.pyplot as plt

# =========================
# STORAGE
# =========================
packets = []
ip_activity = defaultdict(list)   # Flood detection timestamps
port_activity = defaultdict(set)  # Port scanning detection

# =========================
# SETTINGS
# =========================
THRESHOLD = 3      # packets in TIME_WINDOW for flood alert
TIME_WINDOW = 5         # seconds
PORT_SCAN_THRESHOLD = 5 # different ports to detect scanning
SAFE_IPS = ["192.168.29.1"]  # router or trusted devices

# =========================
# DETECTION FUNCTION
# =========================
def detect_anomaly(src_ip, dst_ip, proto, current_time):
    # Flood detection
    timestamps = ip_activity[src_ip]
    ip_activity[src_ip] = [t for t in timestamps if current_time - t <= TIME_WINDOW]

    if len(ip_activity[src_ip]) > THRESHOLD:
        print("\n⚠️ ALERT: Suspicious Activity Detected (Flood)")
        print(f"Source IP: {src_ip}")
        print(f"Packets: {len(ip_activity[src_ip])} in {TIME_WINDOW} sec")
        print(f"Protocol: {proto} → Destination: {dst_ip}\n")

    # Port scan detection
    if proto == 6 or proto == 17:  # TCP or UDP
        if proto == 6:
            port_activity[src_ip].add(dst_port)
        else:
            port_activity[src_ip].add(dst_port)
        if len(port_activity[src_ip]) > PORT_SCAN_THRESHOLD:
            print("\n🚨 ALERT: Possible Port Scanning Detected")
            print(f"Source IP: {src_ip}")
            print(f"Targeted Ports: {sorted(port_activity[src_ip])}\n")

# =========================
# PACKET PROCESSING
# =========================
def process_packet(packet):
    if packet.haslayer(IP):
        ip = packet[IP]
        src = ip.src
        dst = ip.dst
        proto = ip.proto
        now = time.time()

        # Skip broadcast/multicast and safe devices
        if dst.startswith("224.") or dst.startswith("255.") or src in SAFE_IPS or dst in SAFE_IPS:
            return

        # Get destination port for TCP/UDP
        global dst_port
        dst_port = 0
        if packet.haslayer(TCP):
            dst_port = packet[TCP].dport
        elif packet.haslayer(UDP):
            dst_port = packet[UDP].dport

        # Save packet
        packets.append({
            "src": src,
            "dst": dst,
            "protocol": proto,
            "port": dst_port,
            "time": now
        })

        # Track activity
        ip_activity[src].append(now)

        # Detect anomalies
        detect_anomaly(src, dst, proto, now)

        # Print packet info
        print(f"{src} → {dst} | Protocol: {proto} | Port: {dst_port}")

# =========================
# START CAPTURE
# =========================
print("🚀 Capturing packets...\n")
sniff(prn=process_packet, count=50)  # adjust count for longer capture

# =========================
# DATA ANALYSIS
# =========================
df = pd.DataFrame(packets)
print("\n📊 Sample Data:")
print(df.head())

# =========================
# VISUALIZATION
# =========================
# 1. Top talkers
counts = df['src'].value_counts()
plt.figure(figsize=(10,5))
plt.bar(counts.index, counts.values, color='skyblue')
plt.xticks(rotation=90)
plt.title("Top Talkers (Source IP)")
plt.xlabel("Source IP") 
plt.ylabel("Packets")
plt.show()

# 2. Traffic over time
plt.figure(figsize=(10,5))
df['time'] = df['time'] - df['time'].min()  # relative time
plt.plot(df['time'], range(len(df)), marker='o', linestyle='-')
plt.title("Traffic Over Time")
plt.xlabel("Time (seconds)")
plt.ylabel("Packet Number")
plt.show()
